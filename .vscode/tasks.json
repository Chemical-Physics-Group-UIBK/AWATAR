{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Compile PureBasic",
        "type": "shell",
        "command": "pbcompiler",
        "args": [
          "-c",
          "${file}",
          "-o",
          "${fileDirname}/${fileBasenameNoExtension}.app"
        ],
        "options": {
          "env": {
            "PUREBASIC_HOME": "/Applications/PureBasic.app/Contents/Resources",
            "PATH": "/Applications/PureBasic.app/Contents/Resources/compilers:${env:PATH}"
          }
        },
        "problemMatcher": [],
        "group": {
          "kind": "build",
          "isDefault": false
        }
      },
      {
        "label": "Run PureBasic",
        "type": "shell",
        "command": "open",
        "args": [
          "${fileDirname}/${fileBasenameNoExtension}.app"
        ],
        "presentation": {
          "echo": true,
          "reveal": "always",
          "focus": false,
          "panel": "shared"
        },
        "dependsOn": ["Compile PureBasic"],
        "group": {
          "kind": "build",
          "isDefault": true
        }
      }
    ]
  }
  